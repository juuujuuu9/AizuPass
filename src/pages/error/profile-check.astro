---
import Layout from '../../layouts/Layout.astro';
import { AlertCircle } from 'lucide-react';
---

<Layout title="Service Temporarily Unavailable">
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="max-w-md w-full text-center">
      <div class="flex justify-center mb-6">
        <AlertCircle className="h-16 w-16 text-amber-500" />
      </div>
      <h1 class="text-2xl font-bold text-foreground mb-4">
        Service Temporarily Unavailable
      </h1>
      <p class="text-muted-foreground mb-6">
        We're experiencing technical difficulties. Please try again in a few moments.
      </p>
      <div class="space-y-3">
        <a
          href="/"
          class="inline-flex items-center justify-center w-full px-4 py-2 bg-primary text-primary-foreground rounded-lg hover:opacity-90 transition-opacity"
        >
          Try Again
        </a>
        <p class="text-sm text-muted-foreground">
          If the problem persists, contact support.
        </p>
      </div>
    </div>
  </div>
</Layout>
