---
import { EMAIL_ONBOARDING_PENDING_COOKIE } from '../../lib/onboarding-email-cookie';

const returnToRaw = Astro.url.searchParams.get('returnTo');
const safeReturnTo =
  returnToRaw && returnToRaw.startsWith('/') && !returnToRaw.startsWith('//')
    ? returnToRaw
    : '/admin';

const { userId } = Astro.locals.auth();
if (!userId) {
  const back = encodeURIComponent(Astro.url.pathname + Astro.url.search);
  return Astro.redirect(`/login?returnTo=${back}&required=auth`);
}

Astro.cookies.delete(EMAIL_ONBOARDING_PENDING_COOKIE, { path: '/' } as never);
return Astro.redirect(`/onboarding/profile?returnTo=${encodeURIComponent(safeReturnTo)}`);
---
