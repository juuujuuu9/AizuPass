---
import Layout from '../../../layouts/Layout.astro';
import DashboardHeader from '../../../components/DashboardHeader.astro';
import AdminSidebar from '../../../components/AdminSidebar.astro';
import { getOrganizationByOwnerUserId } from '../../../lib/db';

const userId = Astro.locals.user?.id ?? '';
const organization = userId ? await getOrganizationByOwnerUserId(userId) : null;
---

<Layout title="Organization | Billing">
  <div class="min-h-screen bg-background">
    <DashboardHeader
      homeHref="/admin"
      showThemeToggle={true}
      showSignOut={true}
      isAdmin={Astro.locals.isAdmin}
      userEmail={Astro.locals.user?.email ?? ''}
      userFirstName={Astro.locals.user?.firstName ?? ''}
      userLastName={Astro.locals.user?.lastName ?? ''}
      userRole={Astro.locals.user?.role ?? ''}
      organization={organization ? { label: organization.name, href: '/admin/organization' } : undefined}
    />
    <div class="flex min-h-[calc(100vh-4rem)] min-w-0 flex-col md:flex-row">
      {organization && <AdminSidebar variant="organization" active="billing" />}

      <main class="flex-1 px-4 py-10 space-y-6">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <h1 class="text-2xl font-bold text-foreground">Billing</h1>
            <p class="mt-1 text-sm text-muted-foreground">Manage your subscription and payment methods.</p>
          </div>
        </div>

        {!organization ? (
          <div class="rounded-lg border border-(--amber-6) bg-(--amber-2) p-4 text-(--amber-11)">
            <p class="font-medium">No organizer organization found</p>
            <p class="mt-1 text-sm">Create one first to manage billing.</p>
            <a href="/onboarding/organization" class="mt-3 inline-flex rounded-md bg-primary px-3 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90">
              Create organization
            </a>
          </div>
        ) : (
          <section class="rounded-xl border border-border bg-card p-8">
            <div class="text-center py-12">
              <div class="mx-auto h-12 w-12 rounded-full bg-muted flex items-center justify-center mb-4">
                <svg class="h-6 w-6 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                </svg>
              </div>
              <h2 class="text-lg font-semibold text-foreground">Free plan</h2>
              <p class="mt-2 text-sm text-muted-foreground max-w-md mx-auto">
                You're currently on the free plan. Upgrade to unlock more events, staff members, and advanced features.
              </p>
              <button
                type="button"
                disabled
                class="mt-6 inline-flex items-center gap-2 rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground opacity-50 cursor-not-allowed"
              >
                Upgrade plan
                <span class="text-xs bg-amber-500/20 text-amber-600 px-1.5 py-0.5 rounded">Coming soon</span>
              </button>
            </div>
          </section>
        )}
      </main>
    </div>
  </div>
</Layout>
