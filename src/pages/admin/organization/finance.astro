---
import Layout from '../../../layouts/Layout.astro';
import DashboardHeader from '../../../components/DashboardHeader.astro';
import AdminSidebar from '../../../components/AdminSidebar.astro';
import { isUserOrganizerForOrganization, resolveOrganizationForAdminSession } from '../../../lib/db';

const userId = Astro.locals.user?.id ?? '';
const queryOrgId = Astro.url.searchParams.get('id')?.trim() ?? '';

const resolved = userId
  ? await resolveOrganizationForAdminSession(
      userId,
      queryOrgId || undefined,
      Astro.locals.isAdmin,
      '/admin/organization/finance'
    )
  : { status: 'no_access' as const };

if (resolved.status === 'redirect') {
  return Astro.redirect(resolved.to);
}

const organization = resolved.status === 'ok' ? resolved.organization : null;
const orgNavQuery = resolved.status === 'ok' ? resolved.orgNavQuery : '';
const isOrganizerUser = Astro.locals.isAdmin;

if (organization && !(await isUserOrganizerForOrganization(userId, organization))) {
  return Astro.redirect(`/admin/organization${orgNavQuery}`);
}
---

<Layout title="Organization | Finance">
  <div class="min-h-screen bg-background">
    <DashboardHeader
      homeHref="/admin"
      showThemeToggle={true}
      showSignOut={true}
      isAdmin={Astro.locals.isAdmin}
      userEmail={Astro.locals.user?.email ?? ''}
      userFirstName={Astro.locals.user?.firstName ?? ''}
      userLastName={Astro.locals.user?.lastName ?? ''}
      userRole={Astro.locals.user?.role ?? ''}
      organization={
        organization
          ? { label: organization.name, href: `/admin/organization${orgNavQuery}` }
          : undefined
      }
    />
    <div class="flex min-h-[calc(100vh-4rem)] min-w-0 flex-col md:flex-row">
      {organization && (
        <AdminSidebar
          variant="organization"
          active="finance"
          organizationNavQuery={orgNavQuery}
        />
      )}

      <main class="flex-1 px-4 py-10 space-y-6">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <h1 class="text-2xl font-bold text-foreground">Finance</h1>
            <p class="mt-1 text-sm text-muted-foreground">Manage your subscription and payment methods.</p>
          </div>
        </div>

        {!organization ? (
          <div class="rounded-lg border border-(--amber-6) bg-(--amber-2) p-4 text-(--amber-11)">
            {isOrganizerUser ? (
              <>
                <p class="font-medium">No organizer organization found</p>
                <p class="mt-1 text-sm">Create one first to manage finance.</p>
                <a
                  href="/onboarding/organization"
                  class="mt-3 inline-flex rounded-md bg-primary px-3 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90"
                >
                  Create organization
                </a>
              </>
            ) : (
              <>
                <p class="font-medium">Organization not available</p>
                <p class="mt-1 text-sm">
                  This link may be invalid, or you need to pick an organization you belong to.
                </p>
                <a
                  href="/admin"
                  class="mt-3 inline-flex rounded-md bg-primary px-3 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90"
                >
                  Back to organizations
                </a>
              </>
            )}
          </div>
        ) : (
          <section class="rounded-xl border border-border bg-card p-8">
            <div class="text-center py-12">
              <div class="mx-auto h-12 w-12 rounded-full bg-muted flex items-center justify-center mb-4">
                <svg class="h-6 w-6 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                  />
                </svg>
              </div>
              <h2 class="text-lg font-semibold text-foreground">Free plan</h2>
              <p class="mt-2 text-sm text-muted-foreground max-w-md mx-auto">
                You're currently on the free plan. Upgrade to unlock more events, staff members, and advanced features.
              </p>
              <button
                type="button"
                disabled
                class="mt-6 inline-flex items-center gap-2 rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground opacity-50 cursor-not-allowed"
              >
                Upgrade plan
                <span class="text-xs bg-amber-500/20 text-amber-600 px-1.5 py-0.5 rounded">Coming soon</span>
              </button>
            </div>
          </section>
        )}
      </main>
    </div>
  </div>
</Layout>
