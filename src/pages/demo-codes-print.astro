---
import { generateQRCodeBase64 } from '../lib/qr-client';

const DEMO_SUCCESS = 'DEMO-SUCCESS';
const DEMO_ALREADY = 'DEMO-ALREADY';
const DEMO_INVALID = 'DEMO-INVALID';

// Align with app print profile: QR_PRINT + error correction H (see src/config/qr.ts)
const printQrOpts = { profile: 'print' as const };
const successDataUrl = await generateQRCodeBase64(DEMO_SUCCESS, printQrOpts);
const alreadyDataUrl = await generateQRCodeBase64(DEMO_ALREADY, printQrOpts);
const invalidDataUrl = await generateQRCodeBase64(DEMO_INVALID, printQrOpts);

const codes = [
  {
    id: DEMO_SUCCESS,
    label: 'SUCCESS (Green)',
    description: 'Valid check-in — success sound',
    color: '#22c55e',
    dataUrl: successDataUrl,
  },
  {
    id: DEMO_ALREADY,
    label: 'ALREADY CHECKED IN (Yellow)',
    description: 'Duplicate scan warning',
    color: '#f59e0b',
    dataUrl: alreadyDataUrl,
  },
  {
    id: DEMO_INVALID,
    label: 'INVALID (Red)',
    description: 'Error / not found',
    color: '#ef4444',
    dataUrl: invalidDataUrl,
  },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Demo QR Codes — Print</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: white;
        color: #1a1a1a;
        line-height: 1.4;
      }

      .page {
        width: 210mm;
        min-height: 297mm;
        padding: 15mm;
        margin: 0 auto;
        background: white;
      }

      .header {
        text-align: center;
        margin-bottom: 12mm;
        padding-bottom: 6mm;
        border-bottom: 1pt solid #ddd;
      }

      .header h1 {
        font-size: 18pt;
        font-weight: 600;
        margin-bottom: 3mm;
      }

      .header p {
        font-size: 9pt;
        color: #666;
      }

      .codes-grid {
        display: flex;
        flex-direction: column;
        gap: 10mm;
      }

      .code-card {
        display: flex;
        align-items: center;
        gap: 8mm;
        padding: 8mm;
        border: 1pt solid #ddd;
        border-radius: 3mm;
        break-inside: avoid;
      }

      .qr-container {
        flex-shrink: 0;
        width: 45mm;
        height: 45mm;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1pt solid #e5e5e5;
        border-radius: 2mm;
        background: white;
        padding: 2mm;
      }

      .qr-container img {
        width: 40mm;
        height: 40mm;
        object-fit: contain;
      }

      .code-info {
        flex: 1;
      }

      .status-row {
        display: flex;
        align-items: center;
        gap: 2mm;
        margin-bottom: 2mm;
      }

      .status-dot {
        width: 4mm;
        height: 4mm;
        border-radius: 50%;
        flex-shrink: 0;
      }

      .code-label {
        font-size: 14pt;
        font-weight: 600;
      }

      .code-id {
        font-family: ui-monospace, SFMono-Regular, 'SF Mono', Consolas, monospace;
        font-size: 11pt;
        font-weight: 700;
        color: #1a1a1a;
        margin-bottom: 2mm;
        letter-spacing: 0.5pt;
      }

      .code-description {
        font-size: 9pt;
        color: #666;
      }

      .footer {
        margin-top: 12mm;
        padding-top: 6mm;
        border-top: 1pt solid #ddd;
        text-align: center;
        font-size: 8pt;
        color: #999;
      }

      .no-print {
        display: block;
      }

      .print-actions {
        position: fixed;
        bottom: 20px;
        right: 20px;
        display: flex;
        gap: 10px;
        z-index: 100;
      }

      .btn {
        padding: 12px 24px;
        border: none;
        border-radius: 6px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: opacity 0.2s;
      }

      .btn-primary {
        background: #1a1a1a;
        color: white;
      }

      .btn-secondary {
        background: #f5f5f5;
        color: #333;
        border: 1pt solid #ddd;
      }

      .btn:hover {
        opacity: 0.9;
      }

      @media print {
        @page {
          size: A4;
          margin: 0;
        }

        body {
          background: white;
        }

        .page {
          width: 100%;
          min-height: auto;
          padding: 15mm;
          margin: 0;
        }

        .no-print {
          display: none !important;
        }

        .code-card {
          break-inside: avoid;
          page-break-inside: avoid;
        }

        .print-actions {
          display: none !important;
        }
      }

      @media screen and (max-width: 240mm) {
        .page {
          width: 100%;
          padding: 10mm;
        }
      }
    </style>
  </head>
  <body>
    <div class="page">
      <header class="header">
        <h1>Demo QR Codes</h1>
        <p>Training reference sheet — scan these codes to test scanner responses</p>
      </header>

      <div class="codes-grid">
        {codes.map((code) => (
          <div class="code-card">
            <div class="qr-container">
              <img src={code.dataUrl} alt={`QR: ${code.id}`} />
            </div>
            <div class="code-info">
              <div class="status-row">
                <span class="status-dot" style={`background-color: ${code.color};`}></span>
                <span class="code-label">{code.label}</span>
              </div>
              <div class="code-id">{code.id}</div>
              <div class="code-description">{code.description}</div>
            </div>
          </div>
        ))}
      </div>

      <footer class="footer no-print">
        <p>Print this page to PDF for a physical reference card</p>
      </footer>
    </div>

    <div class="print-actions no-print">
      <button class="btn btn-secondary" onclick="window.close()">Close</button>
      <button class="btn btn-primary" onclick="window.print()">Print to PDF</button>
    </div>
  </body>
</html>
