---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Event RSVP & Check-in' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      (function(){var r=document.documentElement;var s=localStorage.getItem('theme');var d=s==='dark'||(!s&&window.matchMedia('(prefers-color-scheme: dark)').matches);r.classList.toggle('dark',d);r.style.colorScheme=d?'dark':'light';})();
    </script>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png?v=1" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
