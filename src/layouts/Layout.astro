---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const SITE_NAME = 'AizuPass';
const SITE_DESCRIPTION = "Modern event check-in system with QR codes. Simple attendee management, offline scanning, and real-time analytics.";
const { title, description, ogImage = '/og-image.png' } = Astro.props;
const fullTitle = title?.trim() ? `${title.trim()} | ${SITE_NAME}` : SITE_NAME;
const fullDescription = description || SITE_DESCRIPTION;
const canonicalUrl = Astro.url.href;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      (function(){var r=document.documentElement;var s=localStorage.getItem('theme');var d=s==='dark'||(!s&&window.matchMedia('(prefers-color-scheme: dark)').matches);r.classList.toggle('dark',d);r.style.colorScheme=d?'dark':'light';})();
      try{if(localStorage.getItem('admin-sidebar-collapsed')==='1')document.documentElement.classList.add('admin-sidebar-collapsed');}catch(e){}
    </script>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png?v=1" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- LO-10: Meta description for SEO -->
    <meta name="description" content={fullDescription} />

    <!-- LO-10: Open Graph tags for social sharing -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={fullDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(ogImage, Astro.url).href} />
    <meta property="og:site_name" content={SITE_NAME} />

    <!-- LO-10: Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={fullDescription} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.url).href} />

    <title>{fullTitle}</title>
  </head>
  <body>
    <!-- LO-10: Noscript fallback for users without JavaScript -->
    <noscript>
      <div style="padding: 2rem; text-align: center; font-family: system-ui, sans-serif;">
        <h1 style="font-size: 1.5rem; margin-bottom: 1rem;">JavaScript Required</h1>
        <p>AizuPass requires JavaScript to function. Please enable JavaScript in your browser settings to continue.</p>
      </div>
    </noscript>
    <slot />
  </body>
</html>
