---
/**
 * Shared admin nav: organization settings area vs per-event workspace.
 * variant=organization — active: overview | staff | finance | settings
 * variant=event — eventId required; active: attendees | import | export | integrations | settings (import/integrations optional via showEventImport)
 */
export interface Props {
  variant: 'organization' | 'event';
  active:
    | 'overview'
    | 'staff'
    | 'finance'
    | 'settings'
    | 'attendees'
    | 'import'
    | 'export'
    | 'integrations';
  eventId?: string;
  /** Appended to organization admin links (e.g. `?id=…` for staff). */
  organizationNavQuery?: string;
  /** On event workspace (?event=): org id for "Manage Events" → `/admin/organization?id=…`; falls back to `/admin` if missing. */
  eventWorkspaceOrganizationId?: string;
  /** Staff members should not see Finance; set from `isUserOrganizerForOrganization`. Default true. */
  showOrganizationFinance?: boolean;
  /** Staff members should not see Import; set from `isUserOrganizerForOrganization` for the event's org. Default true. */
  showEventImport?: boolean;
}

const {
  variant,
  active,
  eventId = '',
  organizationNavQuery = '',
  eventWorkspaceOrganizationId = '',
  showOrganizationFinance = true,
  showEventImport = true,
} = Astro.props;

const linkActive =
  'admin-sidebar-nav-link flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-md bg-primary/10 text-primary';
const linkIdle =
  'admin-sidebar-nav-link flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-md text-muted-foreground hover:bg-muted hover:text-foreground transition-colors';

const mobileTabActive =
  'shrink-0 whitespace-nowrap border-b-[3px] border-foreground py-3 px-1 -mb-px text-sm font-medium text-foreground';
const mobileTabIdle =
  'shrink-0 whitespace-nowrap border-b-[3px] border-transparent py-3 px-1 -mb-px text-sm font-medium text-muted-foreground hover:text-foreground transition-colors';
---

{(variant === 'organization' || (variant === 'event' && eventId)) && (
  <nav
    class="sticky top-0 z-40 min-w-0 border-b border-border bg-card md:hidden"
    aria-label="Admin sections"
  >
    <div class="relative min-w-0">
      <div
        class="header-breadcrumb-scroll flex min-w-0 flex-nowrap items-center gap-6 overflow-x-auto overflow-y-clip overscroll-x-contain px-4 pr-10 [-webkit-overflow-scrolling:touch] sm:pr-12"
      >
        {variant === 'organization' && (
          <>
            <a href={`/admin/organization${organizationNavQuery}`} class={active === 'overview' ? mobileTabActive : mobileTabIdle}>Overview</a>
            <a href={`/admin/organization/staff${organizationNavQuery}`} class={active === 'staff' ? mobileTabActive : mobileTabIdle}>Staff</a>
            {showOrganizationFinance && (
              <a href={`/admin/organization/finance${organizationNavQuery}`} class={active === 'finance' ? mobileTabActive : mobileTabIdle}>Finance</a>
            )}
            <a href={`/admin/organization/settings${organizationNavQuery}`} class={active === 'settings' ? mobileTabActive : mobileTabIdle}>Settings</a>
            <a href="/admin" class={mobileTabIdle}>Manage Organizations</a>
          </>
        )}
        {variant === 'event' && eventId && (
          <>
            <a href={`/admin?event=${eventId}`} class={active === 'attendees' ? mobileTabActive : mobileTabIdle}>Attendees</a>
            {showEventImport && (
              <a href={`/admin/events/import?event=${eventId}`} class={active === 'import' ? mobileTabActive : mobileTabIdle}>Import</a>
            )}
            <a href={`/api/attendees/export?eventId=${eventId}`} class={active === 'export' ? mobileTabActive : mobileTabIdle}>Export</a>
            {showEventImport && (
              <a href={`/admin/events/integrations?event=${eventId}`} class={active === 'integrations' ? mobileTabActive : mobileTabIdle}>Integrations</a>
            )}
            <a href={`/admin/events/edit?event=${eventId}`} class={active === 'settings' ? mobileTabActive : mobileTabIdle}>Settings</a>
            <a
              href={eventWorkspaceOrganizationId ? `/admin/organization?id=${eventWorkspaceOrganizationId}` : '/admin'}
              class={mobileTabIdle}
            >
              Manage Events
            </a>
          </>
        )}
      </div>
      <!-- Match DashboardHeader: fade at overflow edge; pointer-events-none keeps touch scroll on the row -->
      <div
        class="pointer-events-none absolute inset-y-0 -right-px z-10 w-10 bg-linear-to-l from-card to-transparent sm:w-12"
        aria-hidden="true"
      />
    </div>
  </nav>
)}

<aside
  id="admin-sidebar-nav"
  class="admin-sidebar-aside hidden w-64 shrink-0 overflow-hidden border-r border-border bg-card transition-[width,border-color] duration-200 ease-out md:flex md:min-h-0 md:flex-col"
  aria-label="Admin navigation"
>
  <div
    class="admin-sidebar-toolbar hidden shrink-0 bg-muted/25 md:flex md:items-center md:justify-end md:px-1"
  >
    <button
      type="button"
      id="admin-sidebar-toggle"
      class="inline-flex shrink-0 items-center justify-center rounded-md p-1.5 text-muted-foreground transition-colors hover:bg-muted/40 hover:text-foreground"
      aria-controls="admin-sidebar-link-list"
      aria-expanded="true"
      aria-label="Collapse sidebar"
    >
      <svg class="admin-sidebar-toggle-chevron h-3.5 w-3.5 transition-transform duration-200" stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 448 512" aria-hidden="true" xmlns="http://www.w3.org/2000/svg"><path d="M223.7 239l136-136c9.4-9.4 24.6-9.4 33.9 0l22.6 22.6c9.4 9.4 9.4 24.6 0 33.9L319.9 256l96.4 96.4c9.4 9.4 9.4 24.6 0 33.9L393.7 409c-9.4 9.4-24.6 9.4-33.9 0l-136-136c-9.5-9.4-9.5-24.6-.1-34zm-192 34l136 136c9.4 9.4 24.6 9.4 33.9 0l22.6-22.6c9.4-9.4 9.4-24.6 0-33.9L127.9 256l96.4-96.4c9.4-9.4 9.4-24.6 0-33.9L201.7 103c-9.4-9.4-24.6-9.4-33.9 0l-136 136c-9.5 9.4-9.5 24.6-.1 34z"></path></svg>
    </button>
  </div>
  <nav
    id="admin-sidebar-link-list"
    class="admin-sidebar-links min-h-0 flex-1 space-y-1 overflow-y-auto p-4 pt-0"
    aria-label="Section links"
  >
    {variant === 'organization' && (
      <>
        <a
          href={`/admin/organization${organizationNavQuery}`}
          class={active === 'overview' ? linkActive : linkIdle}
          title="Overview"
        >
          <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
          </svg>
          <span class="admin-sidebar-link-label">Overview</span>
        </a>
        <a
          href={`/admin/organization/staff${organizationNavQuery}`}
          class={active === 'staff' ? linkActive : linkIdle}
          title="Staff"
        >
          <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <span class="admin-sidebar-link-label">Staff</span>
        </a>
        {showOrganizationFinance && (
          <a
            href={`/admin/organization/finance${organizationNavQuery}`}
            class={active === 'finance' ? linkActive : linkIdle}
            title="Finance"
          >
            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
            <span class="admin-sidebar-link-label">Finance</span>
          </a>
        )}
        <a
          href={`/admin/organization/settings${organizationNavQuery}`}
          class={active === 'settings' ? linkActive : linkIdle}
          title="Settings"
        >
          <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span class="admin-sidebar-link-label">Settings</span>
        </a>
        <div class="!mt-3 flex w-full flex-col gap-3">
          <div class="w-full shrink-0 border-t border-border" aria-hidden="true" />
          <a href="/admin" class={`${linkIdle} text-xs font-normal`} title="Manage Organizations">
            <svg class="h-[0.67rem] w-[0.67rem] shrink-0" viewBox="0 0 96.154 96.154" aria-hidden="true" fill="currentColor">
              <path
                d="M75.183.561 17.578 46.513c-.951.76-.951 2.367 0 3.126l57.608 45.955c.689.547 1.717.709 2.61.414c.186-.061.33-.129.436-.186c.65-.351 1.057-1.025 1.057-1.765V2.093c0-.736-.405-1.414-1.057-1.762c-.108-.059-.253-.127-.426-.184C76.903-.15 75.874.011 75.183.561z"
              />
            </svg>
            <span class="admin-sidebar-link-label">Manage Organizations</span>
          </a>
        </div>
      </>
    )}
    {variant === 'event' && eventId && (
      <>
        <a href={`/admin?event=${eventId}`} class={active === 'attendees' ? linkActive : linkIdle} title="Attendees">
          <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
          <span class="admin-sidebar-link-label">Attendees</span>
        </a>
        {showEventImport && (
          <a href={`/admin/events/import?event=${eventId}`} class={active === 'import' ? linkActive : linkIdle} title="Import">
            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
            </svg>
            <span class="admin-sidebar-link-label">Import</span>
          </a>
        )}
        <a href={`/api/attendees/export?eventId=${eventId}`} class={active === 'export' ? linkActive : linkIdle} title="Export">
          <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          <span class="admin-sidebar-link-label">Export</span>
        </a>
        {showEventImport && (
          <a
            href={`/admin/events/integrations?event=${eventId}`}
            class={active === 'integrations' ? linkActive : linkIdle}
            title="Integrations"
          >
            <svg class="h-4 w-4 shrink-0" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path
                fill="currentColor"
                d="M33,6A13,13,0,1,0,46,19,13,13,0,0,0,33,6ZM32,21a2,2,0,0,1-4,0V17a2,2,0,0,1,4,0Zm6,0a2,2,0,0,1-4,0V17a2,2,0,0,1,4,0Z"
              />
              <path
                fill="currentColor"
                d="M42,40H12V33.7A8,8,0,0,0,18,26V22a2,2,0,0,0-2-2H15V16a2,2,0,0,0-4,0v4H9V16a2,2,0,0,0-4,0v4H4a2,2,0,0,0-2,2v4a8,8,0,0,0,6,7.7V40a4,4,0,0,0,4,4H42a2,2,0,0,0,0-4Z"
              />
            </svg>
            <span class="admin-sidebar-link-label">Integrations</span>
          </a>
        )}
        <a href={`/admin/events/edit?event=${eventId}`} class={active === 'settings' ? linkActive : linkIdle} title="Settings">
          <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span class="admin-sidebar-link-label">Settings</span>
        </a>
        <div class="!mt-3 flex w-full flex-col gap-3">
          <div class="w-full shrink-0 border-t border-border" aria-hidden="true" />
          <a
            href={eventWorkspaceOrganizationId ? `/admin/organization?id=${eventWorkspaceOrganizationId}` : '/admin'}
            class={`${linkIdle} text-xs font-normal`}
            title="Manage Events"
          >
            <svg class="h-[0.67rem] w-[0.67rem] shrink-0" viewBox="0 0 96.154 96.154" aria-hidden="true" fill="currentColor">
              <path
                d="M75.183.561 17.578 46.513c-.951.76-.951 2.367 0 3.126l57.608 45.955c.689.547 1.717.709 2.61.414c.186-.061.33-.129.436-.186c.65-.351 1.057-1.025 1.057-1.765V2.093c0-.736-.405-1.414-1.057-1.762c-.108-.059-.253-.127-.426-.184C76.903-.15 75.874.011 75.183.561z"
              />
            </svg>
            <span class="admin-sidebar-link-label">Manage Events</span>
          </a>
        </div>
      </>
    )}
  </nav>
</aside>

<script is:inline>
  (function () {
    var STORAGE_KEY = 'admin-sidebar-collapsed';
    var root = document.documentElement;

    function sync() {
      var collapsed = root.classList.contains('admin-sidebar-collapsed');
      var btn = document.getElementById('admin-sidebar-toggle');
      if (btn) {
        btn.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
        btn.setAttribute('aria-label', collapsed ? 'Expand sidebar' : 'Collapse sidebar');
        var icon = btn.querySelector('.admin-sidebar-toggle-chevron');
        if (icon) icon.classList.toggle('rotate-180', collapsed);
      }
    }

    function onToggle() {
      root.classList.toggle('admin-sidebar-collapsed');
      try {
        localStorage.setItem(STORAGE_KEY, root.classList.contains('admin-sidebar-collapsed') ? '1' : '0');
      } catch (e) {}
      sync();
    }

    var btn = document.getElementById('admin-sidebar-toggle');
    if (btn) btn.addEventListener('click', onToggle);
    sync();
  })();
</script>
