---
/**
 * Shared admin nav: organization settings area vs per-event workspace.
 * variant=organization — active: overview | staff | billing | settings
 * variant=event — eventId required; active: attendees | import | export | settings
 */
export interface Props {
  variant: 'organization' | 'event';
  active: 'overview' | 'staff' | 'billing' | 'settings' | 'attendees' | 'import' | 'export';
  eventId?: string;
}

const { variant, active, eventId = '' } = Astro.props;

const linkActive = 'flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-md bg-primary/10 text-primary';
const linkIdle =
  'flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-md text-muted-foreground hover:bg-muted hover:text-foreground transition-colors';

const mobileTabActive =
  'shrink-0 whitespace-nowrap border-b-[3px] border-foreground py-3 px-1 -mb-px text-sm font-medium text-foreground';
const mobileTabIdle =
  'shrink-0 whitespace-nowrap border-b-[3px] border-transparent py-3 px-1 -mb-px text-sm font-medium text-muted-foreground hover:text-foreground transition-colors';
---

{(variant === 'organization' || (variant === 'event' && eventId)) && (
  <nav
    class="sticky top-0 z-40 min-w-0 border-b border-border bg-card md:hidden"
    aria-label="Admin sections"
  >
    <div class="flex flex-wrap items-center gap-6 px-4">
      {variant === 'organization' && (
        <>
          <a href="/admin/organization" class={active === 'overview' ? mobileTabActive : mobileTabIdle}>Overview</a>
          <a href="/admin/organization/staff" class={active === 'staff' ? mobileTabActive : mobileTabIdle}>Staff</a>
          <a href="/admin/organization/billing" class={active === 'billing' ? mobileTabActive : mobileTabIdle}>Billing</a>
          <a href="/admin/organization/settings" class={active === 'settings' ? mobileTabActive : mobileTabIdle}>Settings</a>
        </>
      )}
      {variant === 'event' && eventId && (
        <>
          <a href={`/admin?event=${eventId}`} class={active === 'attendees' ? mobileTabActive : mobileTabIdle}>Attendees</a>
          <a href={`/admin/events/import?event=${eventId}`} class={active === 'import' ? mobileTabActive : mobileTabIdle}>Import</a>
          <a href={`/api/attendees/export?eventId=${eventId}`} class={active === 'export' ? mobileTabActive : mobileTabIdle}>Export</a>
          <a href={`/admin/events/edit?event=${eventId}`} class={active === 'settings' ? mobileTabActive : mobileTabIdle}>Settings</a>
        </>
      )}
    </div>
  </nav>
)}

<aside class="hidden w-64 border-r border-border bg-card md:block">
  <nav class="p-4 space-y-1">
    {variant === 'organization' && (
      <>
        <a href="/admin/organization" class={active === 'overview' ? linkActive : linkIdle}>
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
          </svg>
          Overview
        </a>
        <a href="/admin/organization/staff" class={active === 'staff' ? linkActive : linkIdle}>
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          Staff
        </a>
        <a href="/admin/organization/billing" class={active === 'billing' ? linkActive : linkIdle}>
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
          </svg>
          Billing
        </a>
        <a href="/admin/organization/settings" class={active === 'settings' ? linkActive : linkIdle}>
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Settings
        </a>
      </>
    )}
    {variant === 'event' && eventId && (
      <>
        <a href={`/admin?event=${eventId}`} class={active === 'attendees' ? linkActive : linkIdle}>
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
          Attendees
        </a>
        <a href={`/admin/events/import?event=${eventId}`} class={active === 'import' ? linkActive : linkIdle}>
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
          </svg>
          Import
        </a>
        <a href={`/api/attendees/export?eventId=${eventId}`} class={active === 'export' ? linkActive : linkIdle}>
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Export
        </a>
        <a href={`/admin/events/edit?event=${eventId}`} class={active === 'settings' ? linkActive : linkIdle}>
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Settings
        </a>
      </>
    )}
  </nav>
</aside>
